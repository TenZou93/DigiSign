<%- include('partials/header', { pageTitle: 'Buat Surat', activePage: 'home' }) %>
<div class="container py-4" style="max-width:800px">
  <div class="d-flex align-items-center gap-2 mb-4">
    <i class="bi bi-file-earmark-text" style="font-size:28px;color:#3b82f6"></i>
    <h4 class="mb-0 fw-bold">Buat Surat Online</h4>
  </div>
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <% if (message) { %><div class="alert alert-success"><%= message %></div><% } %>
  <p class="text-muted mb-4">Pilih jenis surat yang ingin Anda buat. Isi data yang diperlukan, dan surat akan langsung diproses untuk ditandatangani.</p>
  <div class="row g-3">
    <% templates.forEach(t => { %>
      <div class="col-md-6">
        <a href="/surat/templates/<%= t.code %>" class="text-decoration-none">
          <div class="card h-100" style="border:1.5px solid #e2e8f0;border-radius:12px;transition:all 0.15s;cursor:pointer">
            <div class="card-body">
              <div class="d-flex align-items-center gap-3">
                <div style="width:44px;height:44px;background:#eff6ff;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                  <i class="bi bi-file-text" style="font-size:20px;color:#3b82f6"></i>
                </div>
                <div>
                  <h6 class="mb-1 fw-bold" style="color:#0f172a"><%= t.name %></h6>
                  <p class="mb-0 text-muted" style="font-size:12px"><%= t.description || '-' %></p>
                </div>
              </div>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
  <div class="mt-4">
    <a href="/" class="btn btn-outline-secondary" style="border-radius:10px"><i class="bi bi-arrow-left"></i> Kembali</a>
  </div>
</div>
<%- include('partials/footer') %>
