<%- include('partials/header', { pageTitle: 'Template Surat', activePage: 'admin' }) %>
<div class="container-fluid py-4 px-4">
  <div class="d-flex align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
      <i class="bi bi-file-earmark-text" style="font-size:24px;color:#3b82f6"></i>
      <h5 class="mb-0 fw-bold">Template Surat</h5>
    </div>
    <a href="/surat/admin/templates/new" class="btn btn-sm text-white" style="background:#3b82f6;border-radius:8px;border:none;padding:6px 14px;font-weight:600"><i class="bi bi-plus"></i> Baru</a>
  </div>
  <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>
  <% if (message) { %><div class="alert alert-success small"><%= message %></div><% } %>
  <div class="row g-3">
    <% templates.forEach(t => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100" style="border:1.5px solid #e2e8f0;border-radius:12px">
          <div class="card-body p-3">
            <div class="d-flex align-items-center gap-2 mb-2">
              <div style="width:36px;height:36px;background:#eff6ff;border-radius:8px;display:flex;align-items:center;justify-content:center">
                <i class="bi bi-file-text" style="font-size:16px;color:#3b82f6"></i>
              </div>
              <div>
                <h6 class="mb-0 fw-bold" style="font-size:13px"><%= t.name %></h6>
                <span class="text-muted" style="font-size:10px">Kode: <%= t.code %></span>
              </div>
            </div>
            <p class="text-muted mb-2" style="font-size:11px"><%= t.description || '-' %></p>
            <div class="small text-muted mb-2">
              <% try { %>
                <%= JSON.parse(t.form_fields || '[]').length %> field
              <% } catch(e) { %>0 field<% } %>
              <% if (t.logo_path) { %> &middot; <i class="bi bi-image" style="color:#3b82f6"></i> Logo<% } %>
            </div>
            <div class="d-flex gap-1">
              <a href="/surat/admin/templates/<%= t.id %>/edit" class="btn btn-sm" style="border:1.5px solid #cbd5e1;border-radius:8px;font-size:10px;padding:3px 10px"><i class="bi bi-pencil"></i> Edit</a>
              <form method="POST" action="/surat/admin/templates/<%= t.id %>/delete" class="d-inline" onsubmit="return confirm('Hapus template ini?')">
                <button class="btn btn-sm" style="border:1.5px solid #fecaca;color:#dc2626;border-radius:8px;font-size:10px;padding:3px 10px"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
<%- include('partials/footer') %>
