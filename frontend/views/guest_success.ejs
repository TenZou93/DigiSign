<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Berhasil - <%= settings.site_name || 'DigiSign' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <% const pc = (settings.primary_color || '#3b82f6').startsWith('#') ? settings.primary_color || '#3b82f6' : '#' + (settings.primary_color || '3b82f6'); %>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Inter',sans-serif; background:linear-gradient(135deg,#f1f5f9,#e2e8f0); min-height:100vh; display:flex; align-items:center; justify-content:center; }
    .card { max-width:480px; width:100%; margin:20px; border:none; border-radius:20px; box-shadow:0 20px 60px rgba(0,0,0,0.1); overflow:hidden; background:#fff; text-align:center; }
    .card-body { padding:40px 32px; }
    .icon-success { width:72px;height:72px;border-radius:50%;background:linear-gradient(135deg,#10b981,#059669);display:inline-flex;align-items:center;justify-content:center;margin-bottom:20px; }
    .code-box { background:#f8fafc; border:2px dashed #cbd5e1; border-radius:12px; padding:16px; margin:16px 0; }
    .code-box .code { font-size:28px; font-weight:800; letter-spacing:4px; color:<%= pc %>; font-family:monospace; }
    .btn-primary { background:<%= pc %>; border:none; border-radius:10px; padding:10px 24px; font-weight:600; }
    .btn-primary:hover { opacity:0.9; }
    .btn-outline { border:1.5px solid #e2e8f0; border-radius:10px; color:#64748b; padding:10px 24px; font-weight:500; text-decoration:none; display:inline-block; }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-body">
      <div class="icon-success"><i class="bi bi-check-lg" style="font-size:36px;color:#fff"></i></div>
      <h3 class="fw-bold" style="color:#059669">Dokumen Berhasil Diupload!</h3>
      <p class="text-muted" style="font-size:14px">Simpan nomor tracking berikut untuk memantau status dokumen Anda.</p>
      <div class="code-box">
        <div class="small text-muted mb-1">Nomor Tracking</div>
        <div class="code"><%= code %></div>
      </div>
      <p class="text-muted small">Gunakan nomor ini untuk cek status dan download dokumen yang sudah ditandatangani.</p>
      <div class="d-flex gap-2 justify-content-center mt-3">
        <a href="/guest/track/<%= code %>" class="btn btn-primary text-white"><i class="bi bi-eye"></i> Lihat Status</a>
        <a href="/" class="btn-outline"><i class="bi bi-house"></i> Beranda</a>
      </div>
    </div>
  </div>
</body>
</html>