<%- include('partials/header', { pageTitle: 'Dashboard', activePage: 'dashboard' }) %>

<div class="top-bar">
  <div>
    <h1><i class="bi bi-grid-1x2"></i> Dashboard</h1>
    <div class="breadcrumb-custom">Selamat datang, <%= user.display_name %>!</div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-3 col-6">
    <div class="card card-modern h-100">
      <div class="card-body-custom d-flex align-items-center gap-3" style="padding:20px">
        <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#3b82f6,#2563eb);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="bi bi-file-earmark-check" style="font-size:22px;color:#fff"></i>
        </div>
        <div>
          <div style="font-size:28px;font-weight:700;color:#0f172a"><%= totalSigned %></div>
          <div style="font-size:12px;color:#64748b">Ditandatangani</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card card-modern h-100">
      <div class="card-body-custom d-flex align-items-center gap-3" style="padding:20px">
        <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#f59e0b,#d97706);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="bi bi-clock" style="font-size:22px;color:#fff"></i>
        </div>
        <div>
          <div style="font-size:28px;font-weight:700;color:#0f172a"><%= totalPending %></div>
          <div style="font-size:12px;color:#64748b">Menunggu</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card card-modern h-100">
      <div class="card-body-custom d-flex align-items-center gap-3" style="padding:20px">
        <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#8b5cf6,#7c3aed);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="bi bi-people" style="font-size:22px;color:#fff"></i>
        </div>
        <div>
          <div style="font-size:28px;font-weight:700;color:#0f172a"><%= totalSigners %></div>
          <div style="font-size:12px;color:#64748b">Signer</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card card-modern h-100">
      <div class="card-body-custom d-flex align-items-center gap-3" style="padding:20px">
        <div style="width:48px;height:48px;border-radius:12px;background:linear-gradient(135deg,#10b981,#059669);display:flex;align-items:center;justify-content:center;flex-shrink:0">
          <i class="bi bi-key" style="font-size:22px;color:#fff"></i>
        </div>
        <div>
          <div style="font-size:28px;font-weight:700;color:#0f172a"><%= totalKeys %></div>
          <div style="font-size:12px;color:#64748b">Kunci</div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-7">
    <div class="card card-modern">
      <div class="card-header-custom">
        <h5><i class="bi bi-clock-history"></i> Tanda Tangan Terbaru</h5>
        <% if (recentSigs.length > 0) { %><a href="/sign" class="small" style="color:#3b82f6;text-decoration:none">Lihat Semua</a><% } %>
      </div>
      <div class="card-body-custom" style="padding:0">
        <% if (recentSigs.length === 0) { %>
          <div class="text-center py-4">
            <i class="bi bi-inbox" style="font-size:40px;color:#cbd5e1"></i>
            <p class="text-muted mt-2" style="font-size:13px">Belum ada dokumen yang ditandatangani.</p>
            <a href="/sign" class="btn btn-primary-custom text-white btn-sm"><i class="bi bi-plus-circle"></i> Tanda Tangani Sekarang</a>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead>
                <tr style="font-size:11px;text-transform:uppercase;letter-spacing:0.5px;color:#64748b">
                  <th class="border-0" style="padding:12px 20px">Dokumen</th>
                  <th class="border-0">Kunci/Signer</th>
                  <th class="border-0">Waktu</th>
                </tr>
              </thead>
              <tbody>
                <% recentSigs.forEach(s => { %>
                  <tr>
                    <td style="padding:10px 20px" class="fw-semibold"><%= s.document_name %></td>
                    <td><span class="badge" style="background:#eff6ff;color:#3b82f6;border-radius:6px;font-weight:500"><%= s.key_label %></span></td>
                    <td style="font-size:13px;color:#64748b"><%= s.signed_at %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="col-md-5">
    <div class="card card-modern">
      <div class="card-header-custom">
        <h5><i class="bi bi-lightbulb"></i> Pintasan</h5>
      </div>
      <div class="card-body-custom">
        <div class="d-grid gap-2">
          <a href="/sign" class="btn btn-primary-custom text-white"><i class="bi bi-pen"></i> Tanda Tangan Dokumen</a>
          <a href="/admin" class="btn text-white" style="background:linear-gradient(135deg,#8b5cf6,#7c3aed);border:none;border-radius:10px;padding:10px;font-weight:600;box-shadow:0 4px 12px rgba(139,92,246,0.3)"><i class="bi bi-people"></i> Kelola Signer</a>
          <a href="/documents?tab=guest" class="btn text-white" style="background:linear-gradient(135deg,#f59e0b,#d97706);border:none;border-radius:10px;padding:10px;font-weight:600;box-shadow:0 4px 12px rgba(245,158,11,0.3)"><i class="bi bi-inbox"></i> Dokumen Guest (<%= totalPending %> pending)</a>
          <a href="/admin/settings" class="btn text-white" style="background:linear-gradient(135deg,#64748b,#475569);border:none;border-radius:10px;padding:10px;font-weight:600"><i class="bi bi-gear"></i> Pengaturan</a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>