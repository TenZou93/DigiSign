<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Dokumen - <%= settings.site_name || 'DigiSign' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .guest-card { max-width: 520px; width: 100%; margin: 20px; border: none; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1); overflow: hidden; background: #fff; }
    .guest-header { background: linear-gradient(135deg, #0f172a, #1e293b); padding: 32px 28px; text-align: center; color: #fff; }
    .guest-header .brand-icon { width: 56px; height: 56px; border-radius: 16px; background: linear-gradient(135deg, #3b82f6, #2563eb); display: inline-flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 12px; box-shadow: 0 8px 24px rgba(59,130,246,0.4); }
    .guest-header h2 { font-size: 22px; font-weight: 700; margin: 0; }
    .guest-header p { color: #94a3b8; font-size: 13px; margin: 6px 0 0; }
    .guest-body { padding: 28px; }
    .btn-submit { background: linear-gradient(135deg, #3b82f6, #2563eb); border: none; border-radius: 12px; padding: 12px; font-weight: 600; box-shadow: 0 4px 16px rgba(59,130,246,0.3); transition: all 0.2s; }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(59,130,246,0.4); }
    .btn-submit:disabled { opacity: 0.6; transform: none; }
    .alert-success { background: #f0fdf4; color: #16a34a; border: 1px solid #bbf7d0; border-radius: 12px; }
    .alert-danger { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; border-radius: 12px; }
    .footer-link { text-align: center; margin-top: 20px; font-size: 13px; color: #64748b; }
    .footer-link a { color: #3b82f6; text-decoration: none; font-weight: 500; }
  </style>
</head>
<body>
  <div class="guest-card">
    <div class="guest-header">
      <div class="brand-icon"><i class="bi bi-shield-check"></i></div>
      <h2><%= settings.site_name || 'DigiSign' %></h2>
      <p>Upload dokumen untuk ditandatangani secara digital</p>
    </div>
    <div class="guest-body">
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success border-0 d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill"></i> <%= message %></div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger border-0 d-flex align-items-center gap-2"><i class="bi bi-exclamation-triangle-fill"></i> <%= error %></div>
      <% } %>

      <form method="POST" action="/guest/upload" enctype="multipart/form-data" onsubmit="document.querySelector('.btn-submit').disabled=true;document.querySelector('.btn-submit').innerHTML='<span class=\'spinner-border spinner-border-sm\'></span> Mengunggah...'">
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px">Nama Anda</label>
          <input type="text" name="guest_name" class="form-control" placeholder="Nama lengkap" style="border-radius:10px;border:1.5px solid #e2e8f0;padding:10px 14px">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px">Email</label>
          <input type="email" name="guest_email" class="form-control" placeholder="email@contoh.com" style="border-radius:10px;border:1.5px solid #e2e8f0;padding:10px 14px">
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:13px">File Dokumen <span class="text-danger">*</span></label>
          <input type="file" name="document" class="form-control" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" required style="border-radius:10px;border:1.5px solid #e2e8f0;padding:10px 14px">
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold" style="font-size:13px">Tujuan Tanda Tangan</label>
          <select name="signer_id" class="form-select" style="border-radius:10px;border:1.5px solid #e2e8f0;padding:10px 14px">
            <option value="">-- Pilih Penandatangan --</option>
            <% signers.forEach(s => { %>
              <option value="<%= s.id %>"><%= s.display_name %><%= s.organization ? ' (' + s.organization + ')' : '' %></option>
            <% }) %>
          </select>
          <div class="form-text">Pilih siapa yang harus menandatangani dokumen Anda</div>
        </div>
        <button type="submit" class="btn btn-submit text-white w-100"><i class="bi bi-cloud-upload"></i> Upload Dokumen</button>
      </form>

      <div class="footer-link">
        <i class="bi bi-shield-lock"></i> Dokumen Anda akan diproses oleh admin kami<br>
        <a href="/auth/login"><i class="bi bi-box-arrow-in-right"></i> Login Admin</a>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
