<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - DigiSign</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); min-height: 100vh; display: flex; align-items: center; }
    .card { border: none; border-radius: 20px; box-shadow: 0 25px 60px rgba(0,0,0,0.3); }
    .btn-primary-custom { background: linear-gradient(135deg, #3b82f6, #2563eb); border: none; border-radius: 12px; padding: 12px; font-weight: 600; box-shadow: 0 4px 12px rgba(59,130,246,0.3); }
    .btn-primary-custom:hover { box-shadow: 0 6px 16px rgba(59,130,246,0.4); }
  </style>
</head>
<body>
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-5">
        <div class="card">
          <div class="card-body p-5">
            <div class="text-center mb-4">
              <div style="width:64px;height:64px;border-radius:16px;background:linear-gradient(135deg,#3b82f6,#2563eb);display:inline-flex;align-items:center;justify-content:center;margin-bottom:16px;box-shadow:0 8px 24px rgba(59,130,246,0.4)">
                <i class="bi bi-shield-check" style="font-size:32px;color:#fff"></i>
              </div>
              <h3 class="fw-bold" style="color:#0f172a">DigiSign</h3>
              <p style="color:#64748b;font-size:14px">Sistem Tanda Tangan Digital</p>
            </div>
            <% if (typeof error !== 'undefined' && error) { %>
              <div class="alert border-0" style="background:#fef2f2;color:#dc2626;border-radius:10px;font-size:13px"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
            <% } %>
            <form action="/auth/login" method="POST">
              <div class="mb-3">
                <label class="form-label fw-semibold" style="font-size:13px">Username</label>
                <input type="text" name="username" class="form-control" required style="border-radius:10px;border:1.5px solid #e2e8f0;padding:12px">
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold" style="font-size:13px">Password</label>
                <input type="password" name="password" class="form-control" required style="border-radius:10px;border:1.5px solid #e2e8f0;padding:12px">
              </div>
              <button type="submit" class="btn btn-primary-custom text-white w-100">
                <i class="bi bi-box-arrow-in-right"></i> Masuk
              </button>
            </form>
            <div class="text-center mt-4">
              <a href="/auth/register" style="color:#3b82f6;text-decoration:none;font-size:14px;font-weight:500">Belum punya akun? <strong>Daftar</strong></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
