<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Verifikasi Tanda Tangan - DigiSign</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%); min-height: 100vh; }
    .card { border: none; border-radius: 20px; box-shadow: 0 25px 60px rgba(0,0,0,0.3); }
    .header-icon { width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; font-size: 2.5rem; }
    .header-icon.valid { background: linear-gradient(135deg, #10b981, #059669); color: #fff; box-shadow: 0 8px 24px rgba(16,185,129,0.4); }
    .header-icon.invalid { background: linear-gradient(135deg, #ef4444, #dc2626); color: #fff; box-shadow: 0 8px 24px rgba(239,68,68,0.4); }
    .detail-row { display: flex; padding: 14px 0; border-bottom: 1px solid #f1f5f9; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { width: 180px; font-weight: 600; color: #64748b; font-size: 13px; }
    .detail-value { flex: 1; font-size: 14px; word-break: break-all; color: #0f172a; }
    .hash-value { font-family: 'Courier New', monospace; font-size: 11px; background: #f1f5f9; padding: 4px 10px; border-radius: 6px; }
    .brand-bar { background: rgba(255,255,255,0.05); border-bottom: 1px solid rgba(255,255,255,0.08); padding: 16px 0; }
    .brand-bar a { color: #60a5fa; text-decoration: none; font-weight: 600; font-size: 18px; }
  </style>
</head>
<body>
  <div class="brand-bar text-center">
    <a href="/"><i class="bi bi-shield-check"></i> DigiSign</a>
  </div>
  <div class="container py-5">
    <div class="row justify-content-center">
      <div class="col-md-7">

        <% if (!sig) { %>
          <div class="card p-5 text-center">
            <div class="header-icon invalid"><i class="bi bi-x-circle"></i></div>
            <h3 class="fw-bold" style="color:#dc2626">Tanda Tangan Tidak Ditemukan</h3>
            <p class="text-muted">Token <code><%= token %></code> tidak valid atau sudah tidak berlaku.</p>
            <a href="/" class="btn btn-primary-custom text-white mt-3">Kembali ke Beranda</a>
          </div>
        <% } else { %>
          <div class="card p-5">
            <div class="header-icon valid"><i class="bi bi-shield-check"></i></div>
            <h3 class="text-center fw-bold mb-1" style="color:#059669">Tanda Tangan Tervalidasi</h3>
            <p class="text-center text-muted mb-4">Dokumen ini telah ditandatangani secara digital</p>

            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-file-earmark-text"></i> Nama Dokumen</div>
              <div class="detail-value fw-bold"><%= sig.document_name %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-person"></i> Ditandatangani Oleh</div>
              <div class="detail-value"><%= sig.display_name %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-key"></i> Kunci Digunakan</div>
              <div class="detail-value"><span class="badge" style="background:#eff6ff;color:#3b82f6;border-radius:6px"><%= sig.key_label %></span> <span style="color:#64748b;font-size:13px"><%= sig.algorithm %></span></div>
            </div>
            <% if (sig.signer_org) { %>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-building"></i> Organisasi</div>
              <div class="detail-value"><%= sig.signer_org %></div>
            </div>
            <% } %>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-calendar"></i> Waktu Tanda Tangan</div>
              <div class="detail-value"><%= sig.signed_at %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-hash"></i> Algoritma</div>
              <div class="detail-value"><%= sig.algorithm %></div>
            </div>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-fingerprint"></i> Document Hash</div>
              <div class="detail-value"><span class="hash-value"><%= sig.document_hash %></span></div>
            </div>
            <div class="detail-row">
              <div class="detail-label"><i class="bi bi-qr-code"></i> Token Verifikasi</div>
              <div class="detail-value"><span class="hash-value"><%= sig.token %></span></div>
            </div>

            <hr style="border-color:#f1f5f9">
            <div class="text-center">
              <small style="color:#94a3b8">
                Dihasilkan oleh <strong>DigiSign</strong> &mdash; Sistem Tanda Tangan Digital RSA-2048/SHA-256
              </small>
            </div>
          </div>
        <% } %>

      </div>
    </div>
  </div>
</body>
</html>
