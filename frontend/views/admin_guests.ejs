<%- include('partials/header', { pageTitle: 'Dokumen Guest', activePage: 'admin_guests' }) %>

<div class="top-bar">
  <div>
    <h1><i class="bi bi-people"></i> Dokumen Guest</h1>
    <div class="breadcrumb-custom">Kelola dokumen yang diunggah oleh pengguna publik</div>
  </div>
</div>

<% if (typeof success !== 'undefined' && success) { %>
  <div class="alert border-0" style="background:#f0fdf4;color:#16a34a;border-radius:10px"><i class="bi bi-check-circle"></i> <%= success %></div>
<% } %>
<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert border-0" style="background:#fef2f2;color:#dc2626;border-radius:10px"><i class="bi bi-exclamation-triangle"></i> <%= error %></div>
<% } %>

<div class="card card-modern">
  <div class="card-header-custom">
    <h5><i class="bi bi-list-ul"></i> Daftar Dokumen Guest</h5>
    <span class="badge" style="background:#eff6ff;color:#3b82f6;border-radius:6px;font-weight:500"><%= docs.length %> dokumen</span>
  </div>
  <div class="card-body-custom" style="padding:0">
    <% if (docs.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size:48px;color:#cbd5e1"></i>
        <p class="text-muted mt-2">Belum ada dokumen dari guest.</p>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead>
            <tr style="font-size:12px;text-transform:uppercase;letter-spacing:0.5px;color:#64748b">
              <th class="border-0" style="padding:14px 20px">Dokumen</th>
              <th class="border-0">Pengirim</th>
              <th class="border-0">Tujuan</th>
              <th class="border-0">Status</th>
              <th class="border-0">Tanggal</th>
              <th class="border-0">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% docs.forEach(d => { %>
              <tr>
                <td style="padding:14px 20px" class="fw-semibold"><%= d.originalname %></td>
                <td>
                  <strong><%= d.guest_name || 'Anonim' %></strong>
                  <% if (d.guest_email) { %><br><small style="color:#64748b"><%= d.guest_email %></small><% } %>
                </td>
                <td>
                  <% if (d.signer_name) { %>
                    <span class="badge" style="background:#f1f5f9;color:#475569;border-radius:6px;font-weight:500"><%= d.signer_name %></span>
                  <% } else { %>
                    <span class="text-muted">-</span>
                  <% } %>
                </td>
                <td>
                  <% if (d.status === 'pending') { %>
                    <span class="badge" style="background:#fef3c7;color:#d97706;border-radius:6px;font-weight:500">Pending</span>
                  <% } else if (d.status === 'approved') { %>
                    <span class="badge" style="background:#dbeafe;color:#2563eb;border-radius:6px;font-weight:500">Disetujui</span>
                  <% } else if (d.status === 'rejected') { %>
                    <span class="badge" style="background:#fef2f2;color:#dc2626;border-radius:6px;font-weight:500">Ditolak</span>
                  <% } else if (d.status === 'signed') { %>
                    <span class="badge" style="background:#f0fdf4;color:#16a34a;border-radius:6px;font-weight:500">Ditandatangani</span>
                  <% } %>
                </td>
                <td style="font-size:13px;color:#64748b"><%= d.created_at %></td>
                <td style="white-space:nowrap">
                  <% if (d.status === 'pending') { %>
                    <form method="POST" action="/admin/guests/<%= d.id %>/approve" class="d-inline">
                      <button class="btn btn-sm text-white" style="background:#10b981;border-radius:8px;font-size:12px"><i class="bi bi-check-lg"></i> Setujui</button>
                    </form>
                    <button class="btn btn-sm" style="border:1.5px solid #fecaca;border-radius:8px;color:#ef4444;font-size:12px" onclick="rejectGuest(<%= d.id %>)" data-bs-toggle="modal" data-bs-target="#rejectModal"><i class="bi bi-x-lg"></i> Tolak</button>
                  <% } else if (d.status === 'approved') { %>
                    <a href="/sign" class="btn btn-sm text-white" style="background:#3b82f6;border-radius:8px;font-size:12px"><i class="bi bi-pen"></i> Tanda Tangani</a>
                    <button class="btn btn-sm" style="border:1.5px solid #10b981;border-radius:8px;color:#10b981;font-size:12px" onclick="markSigned(<%= d.id %>)" data-bs-toggle="modal" data-bs-target="#signedModal"><i class="bi bi-check-all"></i> Tandai Signed</button>
                  <% } else if (d.status === 'signed') { %>
                    <span class="badge" style="background:#f0fdf4;color:#16a34a;border-radius:6px;font-weight:500"><i class="bi bi-check-circle"></i> Selesai</span>
                  <% } else if (d.status === 'rejected' && d.admin_note) { %>
                    <span class="small text-muted" title="<%= d.admin_note %>"><i class="bi bi-info-circle"></i> <%= d.admin_note.substring(0, 30) %></span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius:16px;border:none">
      <form method="POST" id="rejectForm">
        <div class="modal-header" style="border-bottom:1px solid #f1f5f9">
          <h5 class="modal-title fw-bold"><i class="bi bi-x-circle"></i> Tolak Dokumen</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" style="padding:24px">
          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:13px">Alasan Penolakan</label>
            <textarea name="admin_note" class="form-control" rows="4" placeholder="Berikan alasan mengapa dokumen ditolak" style="border-radius:10px;border:1.5px solid #e2e8f0"></textarea>
          </div>
        </div>
        <div class="modal-footer" style="border-top:1px solid #f1f5f9">
          <button type="button" class="btn" style="border:1.5px solid #e2e8f0;border-radius:10px;color:#64748b" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn text-white" style="background:#ef4444;border-radius:10px">Tolak</button>
        </div>
      </form>
    </div>
  </div>
</div>

<div class="modal fade" id="signedModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content" style="border-radius:16px;border:none">
      <form method="POST" id="signedForm">
        <div class="modal-header" style="border-bottom:1px solid #f1f5f9">
          <h5 class="modal-title fw-bold"><i class="bi bi-check-circle"></i> Tandai Sudah Ditandatangani</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body" style="padding:24px">
          <p class="text-muted small">Masukkan ID Signature dari riwayat tanda tangan setelah Anda menandatangani dokumen ini di halaman Tanda Tangan.</p>
          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:13px">ID Signature</label>
            <input type="number" name="signature_id" class="form-control" required placeholder="Contoh: 1" style="border-radius:10px;border:1.5px solid #e2e8f0">
          </div>
        </div>
        <div class="modal-footer" style="border-top:1px solid #f1f5f9">
          <button type="button" class="btn" style="border:1.5px solid #e2e8f0;border-radius:10px;color:#64748b" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn text-white" style="background:#10b981;border-radius:10px">Tandai Signed</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function rejectGuest(id) {
    document.getElementById('rejectForm').action = '/admin/guests/' + id + '/reject';
  }
  function markSigned(id) {
    document.getElementById('signedForm').action = '/admin/guests/' + id + '/mark-signed';
  }
</script>

<%- include('partials/footer') %>