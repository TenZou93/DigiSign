<%- include('partials/header', { pageTitle: 'Sukses', activePage: 'home' }) %>
<div class="container py-5" style="max-width:500px;text-align:center">
  <div style="width:72px;height:72px;background:#f0fdf4;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px">
    <i class="bi bi-check-circle" style="font-size:36px;color:#16a34a"></i>
  </div>
  <h4 class="fw-bold mb-2">Surat Berhasil Dibuat!</h4>
  <p class="text-muted mb-1">Nomor tracking surat Anda:</p>
  <div style="background:#f8fafc;border:2px dashed #cbd5e1;border-radius:12px;padding:12px 20px;display:inline-block;margin:10px 0">
    <span class="font-monospace fw-bold" style="font-size:22px;letter-spacing:2px;color:#0f172a"><%= tracking %></span>
  </div>
  <p class="text-muted small mt-2">Simpan nomor tracking ini untuk memantau status surat Anda.</p>
  <div class="mt-4 d-flex gap-2 justify-content-center">
    <a href="/surat/templates" class="btn btn-outline-primary" style="border-radius:10px"><i class="bi bi-plus"></i> Buat Surat Lain</a>
    <a href="/" class="btn btn-outline-secondary" style="border-radius:10px"><i class="bi bi-house"></i> Beranda</a>
  </div>
</div>
<%- include('partials/footer') %>
